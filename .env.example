# Copy to `.env` for local dev or Docker Compose. Set the same keys in Vercel / your host.

# ----- Database (Atlas) -----
# Vercel/production: mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority
# Windows localhost: if querySrv ECONNREFUSED, use Atlas "standard" connection string (mongodb://host:27017,...)
# and set MONGO_TLS_INSECURE=1 locally only (never on Vercel).
MONGO_URL=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority&appName=Replyrocket
# MONGO_TLS_INSECURE=1

# ----- Public URL (required in production; baked into client at Docker *build* time) -----
# Use https://replyrocket.site — no trailing slash.
NEXT_PUBLIC_BASE_URL=https://replyrocket.site

# ----- Auth -----
# openssl rand -hex 32   OR   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=REPLACE_WITH_RANDOM_32_BYTE_HEX

# Optional: dedicated key for encrypting Razorpay/Meta secrets at rest (defaults to JWT_SECRET).
# APP_SECRETS_KEY=

# ----- HTTP -----
CORS_ORIGINS=*

# ----- AI (Emergent universal LLM) -----
EMERGENT_LLM_BASE_URL=https://integrations.emergentagent.com/llm/v1
EMERGENT_LLM_KEY=

# ----- Razorpay (platform billing: Pro / Growth / Agency subscriptions only) -----
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Must match Razorpay Dashboard → Webhooks → secret for https://www.replyrocket.site/api/webhooks/razorpay
RAZORPAY_WEBHOOK_SECRET=
# Create plans in Razorpay Dashboard → Subscriptions → Plans, then paste plan IDs:
# RAZORPAY_PLAN_PRO_ID=
# RAZORPAY_PLAN_GROWTH_ID=
# RAZORPAY_PLAN_AGENCY_ID=

# ----- Meta / Instagram -----
META_APP_ID=
META_APP_SECRET=
# Meta webhook verification token (must match Developer Portal webhook setup).
META_VERIFY_TOKEN=
# If your Instagram product uses different app credentials:
# META_INSTAGRAM_APP_ID=
# META_INSTAGRAM_APP_SECRET=

# Optional webhook debug logs.
# META_WEBHOOK_DEBUG=1

# ----- Misc -----
# IG_INSECURE_TLS=1
